@page "/"
@using Csbf.Core
@using Csbf.Codegen
@inject HttpClient Http
@inject IJSRuntime JS

<PageTitle>csbf — Brainfuck playground</PageTitle>

<h1 class="title"><span class="name">csbf</span><span class="tagline"> — a Brainfuck toolchain (interpreter · debugger · transpiler) in your browser, powered by C# and WASM</span></h1>
<p class="credit">PROGRAMMED BY MXMGORIN</p>

<div class="row">
    <div class="col-lg-6">
        <label class="form-label">Sample</label>
        <select class="form-select form-select-sm mb-2" @onchange="OnSampleSelected">
            @for (var i = 0; i < _samples.Count; i++)
            {
                <option value="@i">@_samples[i].Name</option>
            }
        </select>

        <label class="form-label">Source</label>
        <textarea class="form-control code" rows="7" @bind="_source" @bind:event="oninput"></textarea>

        <label class="form-label mt-2">
            Input (stdin)
            @if (_awaitingInput)
            {
                <span class="badge bg-warning text-dark">waiting — press Enter to send</span>
            }
        </label>
        <div class="input-group">
            <input class="form-control code" @ref="_inputRef" @bind="_input" @bind:event="oninput"
                   @onkeydown="OnStdinKeyDown" placeholder="stdin — seeds the program, and sends on Enter while it waits" />
            @if (_awaitingInput)
            {
                <button class="btn btn-primary" @onclick="SubmitInput">Send</button>
                <button class="btn btn-outline-secondary" @onclick="SendEof" title="Signal end of input (EOF)">EOF</button>
            }
        </div>

        <div class="btn-toolbar mt-2 gap-2">
            <button class="btn btn-outline-secondary" @onclick="RunBench">⏱ Bench</button>
            <button class="btn btn-primary" @onclick="Run">▶ Run</button>
            <button class="btn btn-outline-secondary" @onclick="StepBack" disabled="@(!CanStepBack)">⏮ Back</button>
            <button class="btn btn-outline-secondary" @onclick="Step">⏭ Step</button>
            <button class="btn btn-outline-secondary" @onclick="Reset">⟲ Reset</button>
            <button class="btn btn-outline-secondary" @onclick="EmitGo">Emit Go</button>
        </div>

        <OptimizationToggles Passes="_passes" PassesChanged="OnPassesChanged" />

        @if (!string.IsNullOrEmpty(_status))
        {
            <div class="alert @(_error ? "alert-danger" : "alert-info") mt-2 py-2 mb-0">@_status</div>
        }

        <label class="form-label mt-2">Output</label>
        <pre class="output">@(_io?.Output)</pre>

        @if (!string.IsNullOrEmpty(_emitted))
        {
            <label class="form-label mt-2">Emitted Go</label>
            <pre class="output">@_emitted</pre>
        }
    </div>

    <div class="col-lg-6">
        @if (_vm is { } vm && vm.Loaded())
        {
            <Registers Vm="vm" />
            <TapeView Vm="vm" />
            <Instructions Vm="vm" Breakpoints="_breakpoints" OnToggleBreakpoint="ToggleBreakpoint" />
        }
        else
        {
            <p class="text-muted">Run or step to load the program, then inspect the tape, registers and instructions here.</p>
        }

        <BenchPanel @ref="_benchPanel" Source="@_source" />
    </div>
</div>

@code {
    private const int RunStepLimit = 5_000_000;

    private sealed record Sample(string Name, string Source, string Input);
    private sealed record ManifestEntry(string Name, string File, string? Input);

    private readonly List<Sample> _samples = [];

    // Optimizer passes are individually toggleable; changing one reloads the VM.
    private OptPasses _passes = OptPasses.All;

    private string _source = "";
    private string _input = "";
    private string _status = "";
    private bool _error;
    private string _emitted = "";

    private bool _awaitingInput;
    private ElementReference _inputRef;
    private bool _shouldFocusInput;
    private bool _scrollToOp;

    private Vm? _vm;
    private WebIo? _io;
    private BenchPanel? _benchPanel;
    private readonly HashSet<int> _breakpoints = [];

    private void Load()
    {
        _io = new WebIo(_input);
        _vm = new Vm(_io);
        _vm.EnableRecording(); // opt in to time-travel so ⏮ Back works
        _emitted = "";
        _awaitingInput = false;
        Info("");
        try
        {
            _vm.Load(_source, _passes);
        }
        catch (Exception ex)
        {
            Fail($"parse error: {ex.Message}");
        }

        Refresh();
    }

    private void OnPassesChanged(OptPasses passes)
    {
        _passes = passes;
        Load(); // reload so the instructions and tape reflect the change
    }

    protected override async Task OnInitializedAsync()
    {
        // Samples live in the repo's /samples folder, served as static web assets.
        try
        {
            var entries = await Http.GetFromJsonAsync<ManifestEntry[]>("samples/manifest.json") ?? [];

            foreach (var e in entries)
            {
                var source = await Http.GetStringAsync($"samples/{e.File}");
                _samples.Add(new Sample(e.Name, source, e.Input ?? ""));
            }

            if (_samples.Count > 0)
            {
                _input = _samples[0].Input;
                _source = _samples[0].Source;
                Load();
            }
        }
        catch (Exception ex)
        {
            Fail($"could not load samples: {ex.Message}");
        }
    }

    private void Reset() => Load();

    private void OnSampleSelected(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var i) && i >= 0 && i < _samples.Count)
        {
            _input = _samples[i].Input;
            _source = _samples[i].Source;
            Load();
        }
    }

    private void Step()
    {
        if (_vm is null || !_vm.Loaded())
        {
            Load();
        }

        if (_vm!.Halted())
        {
            Info("program finished");
            return;
        }

        try
        {
            _vm.Step();
            Info("");
        }
        catch (BrainfuckRuntimeException ex)
        {
            Fail($"runtime error: {ex.Message}");
        }

        Refresh();
    }

    // Only the last N executed ops are reversible (bounded ring buffer in the VM).
    private bool CanStepBack => _vm is { RecordingEnabled: true } && _vm.HistoryDepth > 0;

    private void StepBack()
    {
        if (_vm is null || !_vm.Loaded())
        {
            return;
        }

        if (!_vm.StepBack())
        {
            Info("nothing to step back to");
            return;
        }

        _awaitingInput = false;
        Info(_vm.HistoryDropped && _vm.HistoryDepth == 0
            ? "reached start of recorded history"
            : "");
        Refresh();
    }

    private void Run()
    {
        // Fresh start when nothing is loaded or the program already finished;
        // otherwise continue from where a breakpoint stopped.
        if (_vm is null || !_vm.Loaded() || _vm.Halted())
        {
            Load();
        }

        if (_vm is null || !_vm.Loaded())
        {
            return;
        }

        _awaitingInput = false;
        var steps = 0;
        try
        {
            while (!_vm.Halted())
            {
                // Pause for interactive input when the next op reads and nothing
                // is buffered (and the user hasn't signalled EOF).
                if (_io is { AtEof: false, HasInput: false } && _vm.Peek()?.Kind == OpKind.In)
                {
                    _awaitingInput = true;
                    _shouldFocusInput = true;
                    Info("waiting for input…");
                    break;
                }

                _vm.Step();

                if (_breakpoints.Contains(_vm.Ip))
                {
                    Info($"hit breakpoint at 0x{_vm.Ip:X}");
                    break;
                }

                if (++steps >= RunStepLimit)
                {
                    Fail($"reached step limit ({RunStepLimit:N0}) — possible infinite loop");
                    break;
                }
            }
        }
        catch (BrainfuckRuntimeException ex)
        {
            Fail($"runtime error: {ex.Message}");
        }

        Refresh();
    }

    private void SubmitInput()
    {
        if (_io is null)
        {
            return;
        }

        _io.Feed(_input + "\n"); // line-based: Enter sends a newline
        _input = "";
        Run();
    }

    private void SendEof()
    {
        _io?.SignalEof();
        Run();
    }

    private void OnStdinKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && _awaitingInput)
        {
            SubmitInput();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_shouldFocusInput)
        {
            _shouldFocusInput = false;
            try { await _inputRef.FocusAsync(); }
            catch { /* input may no longer be rendered */ }
        }

        if (_scrollToOp)
        {
            _scrollToOp = false;
            try { await JS.InvokeVoidAsync("csbfScrollToCurrentOp"); }
            catch { /* JS not ready / element not rendered */ }
        }
    }

    private void EmitGo()
    {
        try
        {
            var gen = new GoCodegen();
            new Pipeline(gen).Run(Parser.Parse(_source), _passes);
            _emitted = gen.Emit();
            Info("emitted Go");
        }
        catch (Exception ex)
        {
            Fail($"emit error: {ex.Message}");
        }
    }

    private void RunBench() => _benchPanel?.Run();

    private void ToggleBreakpoint(int ip)
    {
        if (!_breakpoints.Add(ip))
        {
            _breakpoints.Remove(ip);
        }
    }

    private void Refresh()
    {
        // Keep the current instruction row in view after the render.
        _scrollToOp = _vm is { } vm && vm.Loaded();
    }

    private void Info(string msg)
    {
        _status = msg;
        _error = false;
    }

    private void Fail(string msg)
    {
        _status = msg;
        _error = true;
    }
}
